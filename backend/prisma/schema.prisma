generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---

enum UserRole {
  customer
  vendor
  rider
  restaurant
  superadmin
  organization
  admin
}

enum TransactionType {
  funding
  order_payment
  withdrawal
  savings_deposit
}

enum OrderStatus {
  pending
  processing
  shipped
  delivered
  cancelled
}

enum DeliveryStatus {
  assigned
  picked_up
  in_transit
  delivered
}


enum ProcurementStatus {
  evaluating
  approved
  purchased
  shipped
  delivered
  cancelled
}

enum DisputeStatus {
  open
  reviewing
  resolved
  rejected
}

// --- MODELS ---
model Gender {
  id    BigInt @id @default(autoincrement())
  sex   String @db.VarChar(10) // "Male", "Female", etc.
  users User[]
}
model User {
  id              BigInt    @id @default(autoincrement())
  surname         String    @db.VarChar(255)
  firstName       String    @map("first_name") @db.VarChar(255)
  otherName       String?   @map("other_name") @db.VarChar(255)
  
  // Relations to Gender and Location
  genderId        BigInt    @map("gender_id")
  gender          Gender    @relation(fields: [genderId], references: [id])
  
  phone           String?   @unique @db.VarChar(20)
  nationality     String?   @default("Nigerian") @db.VarChar(50)
  
  // Improved Location Relations
  stateId         Int?      @map("state_id")
  state           State?    @relation(fields: [stateId], references: [id])
  lgaId           Int?      @map("lga_id")
  lga             LocalGovernment? @relation(fields: [lgaId], references: [id])
  
  city            String?   @db.VarChar(100)
  address         String    @db.VarChar(255)
  email           String?   @unique @db.VarChar(255)
  nin             String?   @unique @db.VarChar(11)
  passwordHash    String    @map("password_hash") @db.Text
  role            UserRole  @default(customer)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // --- ONE-TO-ONE RELATIONS ---
  wallet          Wallet?
  vendorProfile   Vendor?
  cart            Cart?
  referralJoined  Referral? @relation("Referee")

  // --- ONE-TO-MANY RELATIONS ---
  savingsGoals    SavingsGoal[]
  orders          Order[]
  procurements    ExternalProcurement[]
  disputes        Dispute[]
  
  // Self-Relation for Referrals
  referralsMade   Referral[] @relation("Referrer")
  
  // Relation for Riders (Deliveries)
  deliveries      Delivery[] @relation("RiderDeliveries")

  @@map("users")
}
model Wallet {
  id           BigInt              @id @default(autoincrement())
  userId       BigInt              @unique @map("user_id")
  balance      Decimal             @default(0.00) @db.Decimal(15, 2)
  currency     String              @default("NGN") @db.VarChar(10)
  updatedAt    DateTime            @updatedAt @map("updated_at")
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id              BigInt          @id @default(autoincrement())
  walletId        BigInt          @map("wallet_id")
  amount          Decimal         @db.Decimal(15, 2)
  transactionType TransactionType @map("transaction_type")
  status          String          @default("pending") @db.VarChar(20)
  reference       String?         @unique @db.VarChar(100)
  createdAt       DateTime        @default(now()) @map("created_at")
  wallet          Wallet          @relation(fields: [walletId], references: [id])

  @@map("wallet_transactions")
}

model SavingsGoal {
  id             BigInt   @id @default(autoincrement())
  userId         BigInt   @map("user_id")
  goalName       String   @map("goal_name") @db.VarChar(255)
  targetAmount   Decimal  @map("target_amount") @db.Decimal(15, 2)
  currentBalance Decimal  @default(0.00) @map("current_balance") @db.Decimal(15, 2)
  isLocked       Boolean  @default(true) @map("is_locked")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id])

  @@map("savings_goals")
}

model Vendor {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt   @unique @map("user_id")
  businessName String   @map("business_name") @db.VarChar(255)
  vendorType   String   @map("vendor_type") @db.VarChar(50)
  isVerified   Boolean  @default(false) @map("is_verified")
  rating       Decimal  @default(5.00) @db.Decimal(3, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id])
  products     Product[]

  @@map("vendors")
}

model Product {
  id             BigInt           @id @default(autoincrement())
  vendorId       BigInt           @map("vendor_id")
  name           String           @db.VarChar(255)
  categoryId      Int             @map("category_id")
  description    String?          @db.Text
  image          String?          @db.Text
  ratingStars    Int              @default(0) @map("rating_stars")
  ratingCount    Int              @default(0) @map("rating_count")
  keywords       String[]         @default([])
  basePrice      Decimal          @map("base_price") @db.Decimal(15, 2)
  unitType       String           @default("piece") @map("unit_type") @db.VarChar(20)
  isAvailable    Boolean          @default(true) @map("is_available")
  stockThreshold Int              @default(5) @map("stock_threshold")
  createdAt      DateTime         @default(now()) @map("created_at")
  vendor         Vendor           @relation(fields: [vendorId], references: [id])
  variants       ProductVariant[]
  orderItems     OrderItem[]

  @@map("products")
}

model ProductVariant {
  id            BigInt      @id @default(autoincrement())
  productId     BigInt      @map("product_id")
  size          String?     @db.VarChar(20)
  color         String?     @db.VarChar(50)
  priceOverride Decimal?    @map("price_override") @db.Decimal(15, 2)
  stockQuantity Int         @default(0) @map("stock_quantity")
  sku           String?     @unique @db.VarChar(100)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]

  @@map("product_variants")
}

model Order {
  id              BigInt      @id @default(autoincrement())
  userId          BigInt      @map("user_id")
  totalAmount     Decimal     @map("total_amount") @db.Decimal(15, 2)
  paymentStatus   String      @default("unpaid") @map("payment_status") @db.VarChar(20)
  orderStatus     OrderStatus @default(pending) @map("order_status")
  landmarkAddress String?     @map("landmark_address") @db.Text
  otpCode         String?     @map("otp_code") @db.VarChar(6)
  createdAt       DateTime    @default(now()) @map("created_at")
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
  delivery        Delivery?
  disputes        Dispute[]

  @@map("orders")
}

model OrderItem {
  id              BigInt          @id @default(autoincrement())
  orderId         BigInt          @map("order_id")
  productId       BigInt          @map("product_id")
  variantId       BigInt?         @map("variant_id")
  quantity        Int
  priceAtPurchase Decimal         @map("price_at_purchase") @db.Decimal(15, 2)
  order           Order           @relation(fields: [orderId], references: [id])
  product         Product         @relation(fields: [productId], references: [id])
  variant         ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model Delivery {
  id              BigInt         @id @default(autoincrement())
  orderId         BigInt         @unique @map("order_id")
  riderId         BigInt         @map("rider_id")
  deliveryFee     Decimal        @map("delivery_fee") @db.Decimal(10, 2)
  status          DeliveryStatus @default(assigned)
  assignedAt      DateTime       @default(now()) @map("assigned_at")
  deliveredAt     DateTime?      @map("delivered_at")
  order           Order          @relation(fields: [orderId], references: [id])
  rider           User           @relation("RiderDeliveries", fields: [riderId], references: [id])

  @@map("deliveries")
}

model Referral {
  id           BigInt   @id @default(autoincrement())
  referrerId   BigInt   @map("referrer_id")
  refereeId    BigInt   @unique @map("referee_id")
  bonusAmount  Decimal  @default(500.00) @map("bonus_amount") @db.Decimal(10, 2)
  isPaid       Boolean  @default(false) @map("is_paid")
  createdAt    DateTime @default(now()) @map("created_at")
  referrer     User     @relation("Referrer", fields: [referrerId], references: [id])
  referee      User     @relation("Referee", fields: [refereeId], references: [id])

  @@map("referrals")
}

model ExternalProcurement {
  id                 BigInt            @id @default(autoincrement())
  userId             BigInt            @map("user_id")
  productUrl         String            @map("product_url") @db.Text
  estimatedCost      Decimal           @map("estimated_cost") @db.Decimal(15, 2)
  shippingCustomsFee Decimal           @map("shipping_customs_fee") @db.Decimal(15, 2)
  serviceFee         Decimal           @map("service_fee") @db.Decimal(15, 2)
  finalTotal         Decimal           @map("final_total") @db.Decimal(15, 2)
  status             ProcurementStatus @default(evaluating)
  createdAt          DateTime          @default(now()) @map("created_at")
  user               User              @relation(fields: [userId], references: [id])

  @@map("external_procurements")
}

model Dispute {
  id        BigInt        @id @default(autoincrement())
  orderId   BigInt        @map("order_id")
  userId    BigInt        @map("user_id")
  reason    String        @db.Text
  status    DisputeStatus @default(open)
  createdAt DateTime      @default(now()) @map("created_at")
  order     Order         @relation(fields: [orderId], references: [id])
  user      User          @relation(fields: [userId], references: [id])

  @@map("disputes")
}

model Cart {
  id           String     @id @default(uuid())
  // Optional userId: null for guests, populated for logged-in users
  userId       BigInt?    @unique @map("user_id")
  // sessionId: stored in a cookie/localstorage for guests
  sessionId    String?    @unique @map("session_id")
  items        CartItem[]
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  user         User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  id        BigInt @id @default(autoincrement())
  cartId    String @map("cart_id")
  productId BigInt @map("product_id")
  quantity  Int    @default(1)

  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("cart_items")
}

model Country {
  id     Int     @id @default(autoincrement())
  name   String  @unique @db.VarChar(100)
  states State[]

  @@map("countries")
}

model State {
  id        Int               @id @default(autoincrement())
  name      String            @db.VarChar(100)
  countryId Int               @map("country_id")
  country   Country           @relation(fields: [countryId], references: [id])
  lgas      LocalGovernment[]
  users     User[] // Connects users to their state

  @@map("states")
}

model LocalGovernment {
  id      Int    @id @default(autoincrement())
  name    String @db.VarChar(100)
  stateId Int    @map("state_id")
  state   State  @relation(fields: [stateId], references: [id])
  users   User[] // Connects users to their LGA

  @@map("local_governments")
}
model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique @db.VarChar(100)
  slug     String    @unique // e.g. "electronics"
  products Product[]

  @@map("categories")
}